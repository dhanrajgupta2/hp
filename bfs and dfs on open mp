#include <stdio.h>
#include <omp.h>

#define MAX 100

int visited[MAX];

void dfs_util(int graph[MAX][MAX], int n, int node) {
    visited[node] = 1;
    printf("%d ", node);

    #pragma omp parallel for
    for(int i = 0; i < n; i++) {
        if(graph[node][i] && !visited[i]) {
            #pragma omp critical
            {
                if(!visited[i]) {
                    dfs_util(graph, n, i);
                }
            }
        }
    }
}

void parallel_dfs(int graph[MAX][MAX], int n, int start) {
    for(int i = 0; i < n; i++)
        visited[i] = 0;

    dfs_util(graph, n, start);
}

