// Write a program to implement Parallel Bubble Sort and Merge sort using OpenMP.
//  Use existing algorithms and measure the performance of sequential and parallel algorithms.

// solution

// parallel bubble sort

#include <stdio.h>
#include <omp.h>

int main() {
    int a[] = {9, 5, 1, 4, 3, 8, 2, 7, 6};
    int n = 9;

    double start = omp_get_wtime();

    for (int i = 0; i < n; i++) {

        // Even phase
        #pragma omp parallel for
        for (int j = 0; j < n - 1; j += 2) {
            if (a[j] > a[j + 1]) {
                int temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
        }

        // Odd phase
        #pragma omp parallel for
        for (int j = 1; j < n - 1; j += 2) {
            if (a[j] > a[j + 1]) {
                int temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
        }
    }

    double end = omp_get_wtime();

    printf("Sorted array: ");
    for (int i = 0; i < n; i++)
        printf("%d ", a[i]);

    printf("\nTime: %f sec\n", end - start);

    return 0;
} 

