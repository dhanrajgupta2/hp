# EXP 3 : Implement Min, Max, Sum and Average operations using Parallel Reduction.

# solution 


import numpy as np


# Input array
arr = np.array([10, 20, 5, 8, 15, 3, 12])


# Parallel Reduction Function ( the main logic )
def parallel_reduce(data, operation):
    data = data.copy()
    
    while len(data) > 1:
        new_data = []
        
        for i in range(0, len(data), 2):
            if i + 1 < len(data):
                
                if operation == "sum":
                    new_data.append(data[i] + data[i+1])
                
                elif operation == "min":
                    new_data.append(min(data[i], data[i+1]))
                
                elif operation == "max":
                    new_data.append(max(data[i], data[i+1]))
            
            else:
                new_data.append(data[i])  # carry forward if odd
        
        data = np.array(new_data)
    
    return data[0]


# Operations
sum_result = parallel_reduce(arr, "sum")
min_result = parallel_reduce(arr, "min")
max_result = parallel_reduce(arr, "max")
avg_result = sum_result / len(arr)


# Output
print("Array:", arr)
print("Sum:", sum_result)
print("Min:", min_result)
print("Max:", max_result)
print("Average:", avg_result)
